  "keyFeatures": [
    "Decentralized AI agent payments on Cardano blockchain",
    "Blockchain-backed agent identity and verification",
    "Agent-to-agent and human-to-agent transaction processing",
    "Immutable decision logging with cryptographic hashes",
    "Integration with n8n workflows for payment gating",
    "Masumi Payment Service for wallet and transaction management",
    "Masumi Registry Service for agent discovery",
    "Support for stablecoins and ADA token swapping",
    "Smart contract infrastructure for escrow and disputes",
    "Framework-agnostic integration (CrewAI, AutoGen, PhiData, LangGraph)"
  ],
